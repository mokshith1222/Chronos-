generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// CORE DOMAIN MODELS
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  workspaces    Workspace[]
  activityLogs  ActivityLog[]
  preference    UserPreference?
}

model Workspace {
  id            String    @id @default(cuid())
  name          String
  ownerId       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isArchived    Boolean   @default(false)

  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projects      Project[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  goals         Goal[]
  habits        Habit[]
  notes         Note[]
  folders       Folder[]
  calendarEvents CalendarEvent[]
  activityLogs  ActivityLog[]
  pinnedItems   PinnedItem[]
  searchHistories SearchHistory[]
  savedSearches   SavedSearch[]
  commandLogs     CommandLog[]

  @@index([ownerId])
}

model Project {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  color         String?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isArchived    Boolean   @default(false)
  deletedAt     DateTime?

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks         Task[]
  timeEntries   TimeEntry[]
  goals         Goal[]
  habits        Habit[]

  @@index([workspaceId])
  @@index([isArchived, deletedAt])
}

model Task {
  id            String    @id @default(cuid())
  workspaceId   String
  projectId     String?
  parentTaskId  String?
  title         String
  description   String?
  status        String    @default("TODO")
  priority      String    @default("MEDIUM")
  position      Float     @default(0.0)
  dueDate       DateTime?
  completedAt   DateTime?
  estimatedTime Int?      // in minutes
  actualTime    Int?      // in minutes
  recurrenceRule String?  // e.g. "FREQ=DAILY"
  isFavorite    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isArchived    Boolean   @default(false)
  deletedAt     DateTime?

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  timeEntries   TimeEntry[]
  goals         Goal[]
  habits        Habit[]
  
  parentTask    Task?     @relation("TaskToSubtasks", fields: [parentTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtasks      Task[]    @relation("TaskToSubtasks")
  checklists    ChecklistItem[]
  
  dependencies  TaskDependency[] @relation("TaskDependencies")
  dependents    TaskDependency[] @relation("TaskDependents")

  @@index([workspaceId])
  @@index([workspaceId, isArchived, deletedAt])
  @@index([projectId])
  @@index([parentTaskId])
  @@index([status])
}

model TimeEntry {
  id                 String    @id @default(cuid())
  workspaceId        String
  projectId          String?
  taskId             String?
  description        String?
  startTime          DateTime
  endTime            DateTime?
  duration           Int?      // Duration in seconds
  isProductive       Boolean   @default(true)
  type               String    @default("NORMAL") // NORMAL, POMODORO, STOPWATCH, COUNTDOWN, DEEP_WORK
  mood               Int?      // 1 to 5 rating
  energyLevel        Int?      // 1 to 5 rating
  productivityRating Int?      // 1 to 5 rating
  notes              String?
  tags               String?   // comma-separated list of tags
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task          Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, taskId])
  @@index([workspaceId, projectId])
  @@index([startTime, endTime])
}

model Goal {
  id              String          @id @default(cuid())
  workspaceId     String
  title           String
  description     String?
  category        String          @default("PERSONAL") // PERSONAL, STUDY, WORK, HEALTH, FITNESS, FINANCIAL, READING, LEARNING, CUSTOM
  priority        String          @default("MEDIUM")   // LOW, MEDIUM, HIGH, URGENT
  status          String          @default("ACTIVE")   // ACTIVE, COMPLETED, ARCHIVED, ABANDONED
  targetDate      DateTime?
  progress        Int             @default(0)          // 0 to 100
  currentValue    Float           @default(0)
  targetValue     Float?
  units           String?                              // e.g. "books", "miles", "hours"
  color           String          @default("#3b82f6")
  icon            String          @default("Target")
  tags            String?                              // comma-separated
  notes           String?
  projectId       String?
  taskId          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  milestones      GoalMilestone[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status])
}

model GoalMilestone {
  id          String    @id @default(cuid())
  goalId      String
  title       String
  status      String    @default("TODO") // TODO, IN_PROGRESS, COMPLETED
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// -----------------------------------------------------------------------------
// EXPANDED DASHBOARD MODELS
// -----------------------------------------------------------------------------

model Habit {
  id              String         @id @default(cuid())
  workspaceId     String
  title           String
  description     String?
  frequency       String         @default("DAILY") // DAILY, WEEKLY, MONTHLY, CUSTOM
  customDays      String?                          // Comma-separated days of week e.g. "1,3,5" (Mon, Wed, Fri)
  targetCount     Int            @default(1)       // e.g. 3 times per day
  isNegative      Boolean        @default(false)   // Positive habit (build) vs Negative habit (break)
  status          String         @default("ACTIVE") // ACTIVE, ARCHIVED, PAUSED
  color           String         @default("#f59e0b")
  icon            String         @default("Activity")
  currentStreak   Int            @default(0)
  longestStreak   Int            @default(0)
  projectId       String?
  taskId          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  history         HabitHistory[]
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status])
}

model HabitHistory {
  id          String   @id @default(cuid())
  habitId     String
  status      String   @default("COMPLETED") // COMPLETED, SKIPPED, MISSED
  count       Int      @default(1)           // Number of times completed on this date
  date        DateTime @default(now())       // Day of tracking (normalized to YYYY-MM-DD 00:00:00)
  notes       String?
  createdAt   DateTime @default(now())

  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model Note {
  id            String    @id @default(cuid())
  workspaceId   String
  folderId      String?
  title         String
  content       String?
  isPinned      Boolean   @default(false)
  isFavorite    Boolean   @default(false)
  isArchived    Boolean   @default(false)
  isTrash       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, isTrash, isArchived])
  @@index([workspaceId, isFavorite])
  @@index([folderId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  color       String?
  isAllDay    Boolean  @default(false)
  type        String   @default("EVENT") // EVENT, TIME_BLOCK
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([startTime, endTime])
}

model ActivityLog {
  id            String    @id @default(cuid())
  workspaceId   String
  userId        String?
  action        String
  entityType    String
  entityId      String
  metadata      Json?
  createdAt     DateTime  @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([createdAt])
}

model PinnedItem {
  id            String    @id @default(cuid())
  workspaceId   String
  itemType      String    // "PROJECT", "TASK", "NOTE"
  itemId        String
  createdAt     DateTime  @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  title       String
  isCompleted Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskDependency {
  id              String   @id @default(cuid())
  taskId          String
  dependsOnTaskId String
  createdAt       DateTime @default(now())

  task            Task     @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask   Task     @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

model Folder {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderToSubfolders", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Folder[]  @relation("FolderToSubfolders")
  notes       Note[]

  @@index([workspaceId])
  @@index([parentId])
}

model SearchHistory {
  id          String   @id @default(cuid())
  workspaceId String
  query       String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  query       String
  filters     Json?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model CommandLog {
  id          String   @id @default(cuid())
  workspaceId String
  command     String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model UserPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  preferences Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


